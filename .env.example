# Django Configuration
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# Product Service Database (PostgreSQL)
PRODUCT_DB_NAME=product_db
PRODUCT_DB_USER=product_user
PRODUCT_DB_PASSWORD=change-me-in-production
PRODUCT_DB_HOST=product-db
PRODUCT_DB_PORT=5432

# User Service Database (MySQL)
USER_DB_NAME=user_db
USER_DB_USER=user_user
USER_DB_PASSWORD=change-me-in-production
USER_DB_HOST=user-db
USER_DB_PORT=3306

# Cart Service Database (MySQL)
CART_DB_NAME=cart_db
CART_DB_USER=cart_user
CART_DB_PASSWORD=change-me-in-production
CART_DB_HOST=cart-db
CART_DB_PORT=3306

# Order Service Database (PostgreSQL)
ORDER_DB_NAME=order_db
ORDER_DB_USER=order_user
ORDER_DB_PASSWORD=change-me-in-production
ORDER_DB_HOST=order-db
ORDER_DB_PORT=5432

# Payment Service Database (PostgreSQL)
PAYMENT_DB_NAME=payment_db
PAYMENT_DB_USER=payment_user
PAYMENT_DB_PASSWORD=change-me-in-production
PAYMENT_DB_HOST=payment-db
PAYMENT_DB_PORT=5432

# Shipping Service Database (MySQL)
SHIPPING_DB_NAME=shipping_db
SHIPPING_DB_USER=shipping_user
SHIPPING_DB_PASSWORD=change-me-in-production
SHIPPING_DB_HOST=shipping-db
SHIPPING_DB_PORT=3306

# MySQL Root Password
MYSQL_ROOT_PASSWORD=change-me-in-production

# Service Ports
PRODUCT_SERVICE_PORT=8001
USER_SERVICE_PORT=8002
CART_SERVICE_PORT=8003
ORDER_SERVICE_PORT=8004
PAYMENT_SERVICE_PORT=8005
SHIPPING_SERVICE_PORT=8006
API_GATEWAY_PORT=8080

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# Internal Service Security
SERVICE_INTERNAL_TOKEN=change-me-very-long-random-token

# Inter-service Retry Settings
PRODUCT_SERVICE_MAX_RETRIES=3
PRODUCT_SERVICE_RETRY_BACKOFF=0.1
ORDER_SERVICE_MAX_RETRIES=3
ORDER_SERVICE_RETRY_BACKOFF=0.1

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Service URLs (for inter-service communication)
ORDER_SERVICE_URL=http://order-service:8000
USER_SERVICE_URL=http://user-service:8000
PRODUCT_SERVICE_URL=http://product-service:8000
